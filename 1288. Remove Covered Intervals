//
Leetcode Link: https://leetcode.com/problems/remove-covered-intervals/description/
Approach used: Sorting.
//
class Solution {
public:
    int removeCoveredIntervals(vector<vector<int>>& intervals) {
        sort(intervals.begin(),intervals.end());
        int c=intervals[0][0];
        int d=intervals[0][1];
        int rans=0;
        for(int i=1;i<intervals.size();i++){
            int a=intervals[i][0];
            int b=intervals[i][1];
            if(c<=a && b<=d){
                rans++;
            }else{
                c=intervals[i][0];
                d=intervals[i][1];
            }
        }
        return intervals.size()-rans;
    }
};
