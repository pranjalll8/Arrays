//
Leetcode Link: https://leetcode.com/problems/sum-of-gcd-of-formed-pairs/description
Approach: Sorting + Two Pointers.
//
class Solution {
public:
    int gcd(int a,int b){
        if(b==0)return a;
        return gcd(b,a%b);
    }
    long long gcdSum(vector<int>& nums) {
        int maxi=0;
        vector<int>ans;
        for(int i=0;i<nums.size();i++){
            if(nums[i]>maxi){
                maxi=nums[i];
            }
            if(maxi==nums[i])ans.push_back(nums[i]);
            else{
                ans.push_back(gcd(maxi,nums[i]));
            }
        }
        sort(ans.begin(),ans.end());
        int i=0,j=ans.size()-1;
        vector<int>rans;
        while(i<j){
            int x=ans[i];
            int y=ans[j];
            int z=gcd(x,y);
            rans.push_back(z);
            i++;
            j--;
        }
        long long sumi=0;
        for(int i=0;i<rans.size();i++){
            sumi+=rans[i];
        }
        return sumi;
    }
};
